# Discord application (Developer Portal → Bot)
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# Optional: register slash commands to a single guild (instant — use for Discord test server)
# DISCORD_GUILD_ID=

# Public BookStorage URL — same as BOOKSTORAGE_PUBLIC_ORIGIN on the server (no trailing slash)
BOOKSTORAGE_BASE_URL=https://books.example.com

# SQLite path for encrypted user links
# Local dev: ./data/links.db
# Production (install.sh): /opt/bookstorage-discord/data/links.db
LINK_DB_PATH=./data/links.db

# 32-byte key, base64 — generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# Bot reply language: fr | en
DEFAULT_LOCALE=fr
