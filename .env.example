# Discord application (Developer Portal → Bot)
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# Optional: register slash commands to a single guild (instant). Omit for global commands (~1 h propagation).
# DISCORD_GUILD_ID=

# Public BookStorage instance URL (no trailing slash)
BOOKSTORAGE_BASE_URL=https://books.example.com

# SQLite path for encrypted user links (created automatically)
LINK_DB_PATH=./data/links.db

# 32-byte key, base64 — generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# Bot reply language: fr | en
DEFAULT_LOCALE=fr
