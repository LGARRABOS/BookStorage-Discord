{
  "name": "bookstorage-discord",
  "version": "0.1.0",
  "description": "Optional Discord bot for BookStorage — quick reading actions via slash commands",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "register-commands": "tsx scripts/register-commands.ts",
    "preflight": "node dist/preflight.js",
    "test": "vitest run",
    "lint": "eslint src scripts tests && prettier --check \"src/**/*.ts\" \"scripts/**/*.ts\" \"tests/**/*.ts\" \"*.{json,md,yml}\""
  },
  "dependencies": {
    "better-sqlite3": "^11.9.1",
    "discord.js": "^14.19.3",
    "dotenv": "^16.5.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.21",
    "eslint": "^9.27.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^3.1.4"
  }
}
